# =========================================================================
# Webtoon Mutalaah — contoh konfigurasi persekitaran
# Salin fail ini menjadi .env, kemudian ubah nilai mengikut keperluan:
#   cp .env.example .env
# =========================================================================

# --- Aplikasi ---
NODE_ENV=production
# Port di dalam container (kekal 3000)
PORT=3000
# Port yang didedahkan ke host untuk membuka app di browser
APP_PORT=3000

# --- PostgreSQL ---
# Bila berjalan melalui docker-compose, host ialah nama servis "db".
PGHOST=db
PGPORT=5432
PGUSER=webtoon
PGPASSWORD=ubah_kata_laluan_ini
PGDATABASE=webtoon_mutalaah

# Port PostgreSQL yang didedahkan ke host (debugging sahaja, diikat ke 127.0.0.1)
PGPORT_HOST=5432

# Saiz maksimum connection pool
PG_POOL_MAX=10

# --- Pilihan ---
# Jika diisi, DATABASE_URL akan mengatasi semua tetapan PG* di atas.
# DATABASE_URL=postgres://webtoon:ubah_kata_laluan_ini@db:5432/webtoon_mutalaah

# =========================================================================
# AI Reasoning Provider (Fasa 10+ · Claude diperkenalkan pada Fasa 19)
# =========================================================================
# Pilih enjin penaakulan AI: dummy | ollama | claude
# LALAI 'dummy' (simulasi tempatan, kos 0). Tukar ke 'claude' untuk jadikan
# Claude sebagai Story Director (WAJIB isi CLAUDE_API_KEY di bawah).
AI_PROVIDER=dummy

# --- Claude (Anthropic Messages API) ---
# Hanya digunakan apabila AI_PROVIDER=claude. JANGAN commit kunci sebenar.
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_API_VERSION=2023-06-01
CLAUDE_TIMEOUT_MS=60000
CLAUDE_MAX_TOKENS=2048
CLAUDE_TEMPERATURE=0.4

# --- Ollama (pilihan, local-first) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_MS=60000
OLLAMA_TEMPERATURE=0.4
